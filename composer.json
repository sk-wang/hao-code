{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "sk-wang/hao-code",
    "version": "v0.2.4",
    "type": "library",
    "description": "Terminal-first AI coding agent and PHP SDK for Anthropic-compatible APIs.",
    "keywords": ["ai", "agent", "cli", "coding-agent", "sdk", "anthropic"],
    "homepage": "https://github.com/sk-wang/hao-code",
    "license": "MIT",
    "bin": ["bin/hao-code"],
    "require": {
        "php": "^8.2",
        "illuminate/translation": "^12.56",
        "illuminate/validation": "^12.56",
        "laravel-zero/framework": "^12.0",
        "league/commonmark": "^2.8",
        "symfony/http-client": "^7.0"
    },
    "require-dev": {
        "illuminate/database": "^12.56",
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "pint --test",
        "fix": "pint"
    },
    "extra": {
        "laravel": {
            "dont-discover": [],
            "providers": [
                "App\\Sdk\\HaoCodeSdkServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "support": {
        "issues": "https://github.com/sk-wang/hao-code/issues",
        "source": "https://github.com/sk-wang/hao-code"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
