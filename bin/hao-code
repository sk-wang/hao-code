#!/usr/bin/env php
<?php

use Illuminate\Foundation\Application;
use Symfony\Component\Console\Input\ArgvInput;

define('LARAVEL_START', microtime(true));

$packageRoot = dirname(__DIR__);
$composerBinDir = $GLOBALS['_composer_bin_dir'] ?? null;
$argv = $_SERVER['argv'] ?? ['hao-code'];

if (in_array('--version', $argv, true) || in_array('-V', $argv, true)) {
    $composerJsonPath = $packageRoot.'/composer.json';
    $version = 'dev';

    if (is_file($composerJsonPath)) {
        $composer = json_decode((string) file_get_contents($composerJsonPath), true) ?? [];
        $version = is_string($composer['version'] ?? null) && $composer['version'] !== ''
            ? $composer['version']
            : $version;
    }

    $displayVersion = str_starts_with($version, 'v') ? $version : 'v'.$version;
    fwrite(STDOUT, "Hao Code {$displayVersion}\n");
    exit(0);
}

$autoloadCandidates = array_filter([
    $GLOBALS['_composer_autoload_path'] ?? null,
    is_string($composerBinDir) ? dirname($composerBinDir).'/autoload.php' : null,
    $packageRoot.'/vendor/autoload.php',
    dirname(__DIR__, 3).'/autoload.php',
], static fn ($path) => is_string($path) && $path !== '');

$autoloadPath = null;

foreach ($autoloadCandidates as $candidate) {
    if (is_file($candidate)) {
        $autoloadPath = $candidate;
        break;
    }
}

if ($autoloadPath === null) {
    fwrite(STDERR, "Unable to locate Composer autoload.php.\n");
    exit(1);
}

$composerVendorDir = dirname($autoloadPath);
putenv("COMPOSER_VENDOR_DIR={$composerVendorDir}");
$_ENV['COMPOSER_VENDOR_DIR'] = $composerVendorDir;
$_SERVER['COMPOSER_VENDOR_DIR'] = $composerVendorDir;

require $autoloadPath;

$pathResolver = new \App\Support\Runtime\StoragePathResolver;

$cacheDirectory = $pathResolver->resolveCacheDirectory(
    packageRoot: $packageRoot,
    autoloadPath: $autoloadPath,
);

if (is_string($cacheDirectory) && $cacheDirectory !== '') {
    if (! is_dir($cacheDirectory)) {
        mkdir($cacheDirectory, 0755, true);
    }

    $cachePaths = [
        'APP_SERVICES_CACHE' => $cacheDirectory.'/services.php',
        'APP_PACKAGES_CACHE' => $cacheDirectory.'/packages.php',
        'APP_CONFIG_CACHE' => $cacheDirectory.'/config.php',
        'APP_ROUTES_CACHE' => $cacheDirectory.'/routes-v7.php',
        'APP_EVENTS_CACHE' => $cacheDirectory.'/events.php',
    ];

    foreach ($cachePaths as $envKey => $path) {
        putenv("{$envKey}={$path}");
        $_ENV[$envKey] = $path;
        $_SERVER[$envKey] = $path;
    }
}

$storagePath = $pathResolver->resolve(
    packageRoot: $packageRoot,
    autoloadPath: $autoloadPath,
);

if (is_string($storagePath) && $storagePath !== '') {
    if (! is_dir($storagePath)) {
        mkdir($storagePath, 0755, true);
    }

    putenv("LARAVEL_STORAGE_PATH={$storagePath}");
    $_ENV['LARAVEL_STORAGE_PATH'] = $storagePath;
    $_SERVER['LARAVEL_STORAGE_PATH'] = $storagePath;
}

/** @var Application $app */
$app = require $packageRoot.'/bootstrap/app.php';

if (is_string($storagePath) && $storagePath !== '') {
    if (! is_dir($storagePath)) {
        mkdir($storagePath, 0755, true);
    }

    $app->useStoragePath($storagePath);
}

array_splice($argv, 1, 0, ['hao-code']);
$_SERVER['argv'] = $argv;
$_SERVER['argc'] = count($argv);

$status = $app->handleCommand(new ArgvInput($argv));

exit($status);
